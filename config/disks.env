#!/bin/bash
# =============================================================================
# config/disks.env
# CRITICO: mai /dev/sda/sdb/sdc — l'enumerazione puo' cambiare tra un boot e
# l'altro, soprattutto con 3 dischi quasi identici collegati insieme.
# Popola questi valori con l'output REALE di scripts/00-preflight.sh
# (lsblk -d -o NAME,SIZE,MODEL,SERIAL,TRAN) eseguito a rig assemblato,
# prima di generare la ISO definitiva.
# =============================================================================

# Seriale disco (colonna SERIAL di lsblk) — usato per lo storage 'match' in autoinstall
DEVIN_DISK_SERIAL="PNY213821092201013D8"
HERMES_DISK_SERIAL="OCZ-DM2287ZA59Z7J3UJ"
TEACHER_DISK_SERIAL="WD-WXW0E69SSR66"

# Se il disco non espone un serial affidabile (capita con alcuni USB-SATA),
# fallback su path fisico stabile /dev/disk/by-path/... invece di by serial.
# Lascia vuoto se usi il serial.
DEVIN_DISK_BYPATH=""
HERMES_DISK_BYPATH=""
TEACHER_DISK_BYPATH=""
