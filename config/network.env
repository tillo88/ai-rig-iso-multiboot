#!/bin/bash
# =============================================================================
# config/network.env
# Durante l'INSTALL si usa DHCP su qualunque NIC risponda (robusto, zero rischio
# di doppio IP). L'IP statico definitivo viene scritto dal ruolo al primo boot,
# vincolato al MAC address reale della NIC — non al nome (enp0s31f6 ecc. può
# cambiare, il MAC no).
# =============================================================================

STATIC_IP="192.168.111.177/24"
GATEWAY="192.168.111.254"
DNS_SERVERS="8.8.8.8 8.8.4.4 192.168.111.254"

# TODO: compila dopo aver identificato la NIC fisica del rig (vedi scripts/00-preflight.sh
# oppure 'ip link' + 'ethtool -i <iface>' a rig assemblato).
LAN_MAC="2c:f0:5d:56:08:bc"

# MAC per Wake-on-LAN (di solito coincide con LAN_MAC, stessa interfaccia)
WOL_MAC="2c:f0:5d:56:08:bc"
