#!/bin/bash
# =============================================================================
# config/rig.env — impostazioni globali di build (non di runtime sul rig)
# =============================================================================

WORK_DIR="${HOME}/ai-rig-iso-build"
CACHE_DIR="${WORK_DIR}/cache"
ISO_MOUNT="${WORK_DIR}/iso-mount"
ISO_CUSTOM="${WORK_DIR}/iso-custom"
NOCLOUD_DIR="${WORK_DIR}/nocloud"
OUTPUT_ISO="${WORK_DIR}/ubuntu-24.04-ai-rig-multiboot.iso"

# NB (2026-07-11): usare il nome col POINT-RELEASE (24.04.4), non il generico
# "ubuntu-24.04-live-server-amd64.iso" che su releases.ubuntu.com dà 404 — è la
# trappola del link vecchio. Quando esce 24.04.5 aggiorna qui + l'hash in
# config/artifacts.sha256 (l'attuale e907d92e… è verificato per la .4).
UBUNTU_ISO_URL="https://releases.ubuntu.com/24.04/ubuntu-24.04.4-live-server-amd64.iso"
UBUNTU_ISO_NAME="ubuntu-24.04.4-live-server-amd64.iso"
UBUNTU_ISO_PATH="${WORK_DIR}/${UBUNTU_ISO_NAME}"

# Utente di default su TUTTI e 3 i dischi/ruoli
DEFAULT_HOSTNAME_PREFIX="tilloGPT"   # diventa tilloGPT-devin / -hermes / -teacher
DEFAULT_USERNAME="tillo"
# Hash generato con: mkpasswd -m sha-512 (o: openssl passwd -6)
# ATTENZIONE:  — CAMBIALA al primo accesso (vedi README).
DEFAULT_PASSWORD_HASH='$6$rounds=4096$tilloGPTsalt$3z8O8U6b7C1t8m5vQ2b8yGZ2s9m8s0m6d3n0l7X9YB0kQx9mZ1kQvY8Z0mQpC1Z0mQpC1Z0mQpC1Z0mQpC1'

# Architetture CUDA target: Pascal (1080/1080Ti = sm_61), Turing (1660S/1660Ti = sm_75), Ampere (A2000 = sm_86)
CUDA_ARCHS="61;75;86"

# =============================================================================
# MOTORE DI INFERENZA — scelta al momento del build
#   "beellama" = fork Anbeeld/beellama.cpp: KV cache TurboQuant/TCQ (4x-7.5x vs il
#                ~2x di q8_0), DFlash speculative decoding (serve un drafter
#                dedicato al modello, oggi nessuno dei nostri 3 ce l'ha),
#                reasoning-loop guard. Mantiene tutti i tool/flag di llama.cpp.
#   "mainline" = ggml-org/llama.cpp ufficiale.
#
# REVERSIBILE: i cache type turbo* sono SOLO runtime, non toccano i .gguf.
# Puoi passare da uno all'altro con scripts/swap-llama-flavor.sh senza
# riscaricare o riconvertire nulla.
#
# ⚠️ NON usare MAI i formati peso TQ3_1S/TQ4_1S di beellama con llama-quantize:
#    quelli riscrivono il GGUF e mainline non li apre piu'. Sola andata.
#
# ⚠️ I cache type turbo* richiedono Flash Attention. I benchmark upstream sono su
#    Ampere (RTX 3090). Tu hai 3 GPU Pascal (sm_61): FA su Pascal e' supportata ma
#    poco battuta. MISURA prima di fidarti (vedi README sezione BeeLlama).
# =============================================================================
LLAMA_FLAVOR="beellama"   # "beellama" | "mainline"

if [ "$LLAMA_FLAVOR" = "beellama" ]; then
    LLAMA_REPO="https://github.com/Anbeeld/beellama.cpp.git"
    # FA_ALL_QUANTS e' RICHIESTO dai cache type turbo/TCQ. Allunga parecchio la
    # compilazione (compila tutte le combinazioni di kernel), ma la facciamo una
    # volta sola sulla build machine e la copiamo su tutti e 3 i dischi.
    LLAMA_CMAKE_EXTRA="-DGGML_CUDA_FA=ON -DGGML_CUDA_FA_ALL_QUANTS=ON"
    LLAMA_CACHE_TYPE_K="turbo4"
    LLAMA_CACHE_TYPE_V="turbo3_tcq"
    LLAMA_FLASH_ATTN="on"
else
    LLAMA_REPO="https://github.com/ggerganov/llama.cpp.git"
    LLAMA_CMAKE_EXTRA=""
    LLAMA_CACHE_TYPE_K="q8_0"
    LLAMA_CACHE_TYPE_V="q8_0"
    LLAMA_FLASH_ATTN="auto"
fi

# Driver / CUDA — PIN esplicito, non "latest". Verifica compatibilità Pascal prima di alzare versione.
NVIDIA_DRIVER_URL="https://us.download.nvidia.com/XFree86/Linux-x86_64/570.86.10/NVIDIA-Linux-x86_64-570.86.10.run"
CUDA_TOOLKIT_URL="https://developer.download.nvidia.com/compute/cuda/12.8.0/local_installers/cuda_12.8.0_570.86.10_linux.run"
