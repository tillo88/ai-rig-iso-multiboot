#!/bin/bash
# Ruolo: DEVIN — coding/debug agent, reasoning/planning/decoding model
ROLE_NAME="devin"
ROLE_HOSTNAME="tilloGPT-devin"
ROLE_DISK_SERIAL_VAR="DEVIN_DISK_SERIAL"     # nome variabile da leggere in disks.env
ROLE_DISK_BYPATH_VAR="DEVIN_DISK_BYPATH"

ROLE_MODEL_FILE="Ornith-1.0-35B-A3B-MXFP4_MOE_Q8_0_F16-Imatrix.gguf"   # jashepp, 20.7GB, MoE 35B/A3B, coding-agent
ROLE_MMPROJ_FILE=""                          # vuoto = nessun mmproj per questo ruolo

ROLE_LLAMA_PORT=8080
ROLE_CTX_SIZE=12288                          # parti conservativo, sali dopo test (32GB RAM totali)
ROLE_TEMP=0.7                                # community esempi usano 0.9; abbassa a 0.2-0.4 se vuoi output piu' deterministico per il coding
ROLE_TOP_P=0.9
ROLE_REPEAT_PENALTY=1.0                      # 1.0 = disattivato, come da esempi ufficiali del modello (MoE + repeat penalty alto puo' penalizzare token di codice ripetuti legittimi)
ROLE_EXTRA_ARGS="--top-k 20 --min-p 0.01 --slot-save-path /opt/ai-rig/kv-sessions"

ROLE_APT_FILE="packages/devin.apt"
ROLE_PIP_FILE="requirements/devin.txt"
