#!/bin/bash
# Ruolo: HERMES — chat interattiva con memoria persistente + vision + agent framework
#
# Modello: DavidAU Qwen3.6-40B-...-Deckard-Heretic-Uncensored-Thinking-NEO-CODE
# (Apache 2.0). Verificato: 40B DENSE (non MoE, espanso da Qwen3.6-27B, 96 layer) +
# supporta vision (mmproj dedicato nel repo). Uncensored/"heretic"-abliterato per
# design del creatore, tono forte/diretto di default (a differenza di Devin/Teacher
# che sono MoE): aspettati token/sec piu' bassi qui, tutti i 40B parametri sono
# attivi ad ogni token (Devin/Teacher ne attivano solo ~3B). Trade-off accettato
# per personalita'/qualita' su questo ruolo, dove la latenza conta meno.
# Orchestrazione: Hermes-Agent (github.com/NousResearch/hermes-agent, MIT,
# model-agnostic) sopra questo backend per persona/memoria/tool/skill ComfyUI.
# Vision auto-instradata da Hermes-Agent al modello principale (ce l'ha di suo).
ROLE_NAME="hermes"
ROLE_HOSTNAME="tilloGPT-hermes"
ROLE_DISK_SERIAL_VAR="HERMES_DISK_SERIAL"
ROLE_DISK_BYPATH_VAR="HERMES_DISK_BYPATH"

ROLE_MODEL_FILE="Qwen3.6-40B-Deck-Opus-NEO-CODE-HERE-2T-OT-Q6_K.gguf"  # DavidAU, ~32GB
# Prendi l'mmproj dalla stessa pagina HF (file listing) — piu' di uno disponibile,
# ne serve UNO solo nella stessa cartella del gguf. Conferma nome esatto prima del download.
ROLE_MMPROJ_FILE="mmproj-F32.gguf"

ROLE_LLAMA_PORT=8080
ROLE_CTX_SIZE=16384        # il creatore raccomanda un minimo 8k-16k per questo merge; sali solo dopo test
# Sampling ufficiali del model card, modalita' "Thinking - uso generale":
ROLE_TEMP=1.0
ROLE_TOP_P=0.95
ROLE_REPEAT_PENALTY=1.0    # repetition_penalty=1.0 = disattivato, come da creatore
ROLE_EXTRA_ARGS="--top-k 20 --min-p 0.0 --presence-penalty 0.0 --slot-save-path /opt/ai-rig/kv-sessions"
# NOTA: --cache-type-k/v e --flash-attn NON stanno qui: sono derivati da
# LLAMA_FLAVOR in config/rig.env e applicati a TUTTI e 3 i ruoli.
# Alternative dal model card se preferisci meno "temperatura":
#   coding preciso:      temp=0.6 top_p=0.95 (resto invariato)
#   instruct/non-thinking: temp=0.7 top_p=0.80 presence_penalty=1.5

ROLE_APT_FILE="packages/hermes.apt"
ROLE_PIP_FILE="requirements/hermes.txt"

# AutoMem condiviso tra i 3 ruoli via 4° disco — vedi README sezione "Memoria condivisa".
ENABLE_AUTOMEM=true
AUTOMEM_API_PORT=8001

# Hermes-Agent (github.com/NousResearch/hermes-agent) va installato via pip/installer
# separatamente sul disco HERMES — non fa parte ancora dell'autoinstall automatizzato,
# è il prossimo pezzo da costruire (vedi chat).
