# /etc/ai-rig-bot/config.env
# Permessi consigliati: chmod 600, chown pi:pi (contiene il BOT_TOKEN)

BOT_TOKEN="RECUPERA_DA_config/rig.env_SUL_TUO_PROGETTO_ISO"
RIG_MAC="AA:BB:CC:DD:EE:FF"
RIG_IP="192.168.1.100"
RIG_API_PORT="8080"
RIG_SSH_USER="tillo"
RIG_SSH_KEY="/home/pi/.ssh/ai_rig"          # chiave privata del bot, la .pub va in cache/ai-rig-bot.pub del progetto ISO
RIG_VERIFY_LOG="/var/log/ai-rig-verify.log"

# Chi puo' comandare il bot. ID numerico Telegram (consigliato, immutabile) — scrivi
# a @userinfobot su Telegram per ottenere il tuo. Separati da virgola.
ALLOWED_CHAT_IDS="CHANGEME_TUO_CHAT_ID"

# Fase B (opzionale, sperimentale) — vedi README-netboot.md. Lascia false finche'
# non hai VERIFICATO manualmente che il tuo GRUB ha i moduli net/efinet/tftp.
ENABLE_NETBOOT_SELECT="false"
TFTP_GRUB_TARGET_FILE="/srv/tftp/grub_target"
