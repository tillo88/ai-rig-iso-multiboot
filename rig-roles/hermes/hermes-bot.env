# /etc/hermes-bot/config.env
# Permessi consigliati: chmod 600, chown tillo:tillo (contiene il BOT_TOKEN).
#
# Crea un bot dedicato con @BotFather (SEPARATO da Pi/devin/teacher) e incolla
# qui il token: cosi' la chat di Hermes resta pulita, non impastata col resto.

BOT_TOKEN="8960053927:AAFB3VWrzH0QuPoHssa3yvXS_uKY7-NC5iQ"
ALLOWED_CHAT_IDS="845221624"

# Hermes-Agent CLI (installato per l'utente tillo dallo stage hermes-extras).
HERMES_BIN="hermes"
HERMES_ONESHOT_FLAG="-z"
HERMES_HOME="/home/tillo"
# 40B denso: tutte le richieste possono essere lente, timeout generoso.
HERMES_TIMEOUT_SECONDS="300"

# llama-server del ruolo hermes, solo per /status (di norma non cambiare):
LLAMA_URL="http://localhost:8080"
ROLE_FILE="/etc/ai-rig/role"

POLL_INTERVAL_SECONDS="15"
