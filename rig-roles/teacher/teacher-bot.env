# /etc/teacher-bot/config.env
# Permessi consigliati: chmod 600, chown root:root (contiene il BOT_TOKEN; il
# servizio gira come root per poter riavviare llama-server@teacher).
#
# Crea un bot dedicato con @BotFather (SEPARATO da quello Pi e da devin/hermes,
# per non impastare le chat) e incolla qui il token.

BOT_TOKEN="8735417596:AAFWfcLR7S0_aLGYUpl7b5rJ02ScDddEjoc"
ALLOWED_CHAT_IDS="845221624"

# llama-server del ruolo teacher (di norma non cambiare):
LLAMA_URL="http://localhost:8080"
LLAMA_SERVICE="llama-server@teacher.service"
ROLE_FILE="/etc/ai-rig/role"

# Opzionale: nome modello nel payload (llama-server lo ignora, utile solo nei log)
MODEL_NAME=""

# Watchdog: ogni POLL_INTERVAL_SECONDS controlla /health; dopo
# WATCHDOG_FAIL_THRESHOLD fallimenti consecutivi manda l'alert.
POLL_INTERVAL_SECONDS="15"
WATCHDOG_FAIL_THRESHOLD="3"
HEALTH_TIMEOUT_SECONDS="8"

# /ask: il teacher è un modello Thinking, può essere lento -> timeout generoso.
ASK_TIMEOUT_SECONDS="300"
